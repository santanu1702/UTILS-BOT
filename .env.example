# Copy this file to .env and fill in your own values for local/Docker Compose use.
# On Render, set these in the Dashboard (Environment tab) or via render.yaml instead —
# Render does not read .env files.

# --- Required ---
# Telegram bot token from https://telegram.me/BotFather
BOT_TOKEN=0000000000:aaaaaaaaaaaaaaaaaaaa
# MTProto credentials from https://my.telegram.org (used to upload large media)
API_HASH=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
API_ID=0000000
# Comma-separated Telegram user IDs with administrator permissions
BOT_ADMINS=000000,000000,000000

BOT_LANGUAGE=en_US
DEBUG=0

# --- Optional plugin integrations ---
HADITH_SEARCH_ENDPOINT=
# https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=
WHISPER_MODEL_PATH=
# https://github.com/ieasybooks/tafrigh/blob/main/README.en.md (space-separated tokens)
WIT_CLIENT_ACCESS_TOKENS=
# https://github.com/ieasybooks/tahweel - path to a service account credentials JSON file
SERVICE_ACCOUNT_FILE=
# https://github.com/simonw/llm-gemini
LLM_GEMINI_KEY=
# https://github.com/angerman/llm-groq
GROQ_API_KEY=
LLM_TRANSCRIPTION_MODEL=groq/whisper-large-v3
# Aurora-compatible dispenser for Google Play APK downloads (anonymous auth disabled if unset)
GPLAY_DISPENSER_URL=

# --- Optional: used by the /update admin command for git-less self-updates ---
# UPDATE_REPO_URL=https://github.com/yshalsager/telegram-utils-bot.git
# UPDATE_REPO_BRANCH=master

# --- Optional: base URL of a bgutil-ytdlp-pot-provider instance ---
# (defaults to http://bgutil-provider:4416, matching docker-compose.yml)
# BGUTIL_PROVIDER_URL=

